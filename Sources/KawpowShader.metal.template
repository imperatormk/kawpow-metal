// ============================================================
// Main Mining Kernel
// ============================================================

kernel void kawpow_search(
    device SearchResults* g_output [[buffer(0)]],
    constant hash32_t* g_header [[buffer(1)]],
    device const dag_t* g_dag [[buffer(2)]],
    constant ulong* start_nonce_buf [[buffer(3)]],
    constant ulong* target_buf [[buffer(4)]],
    constant uint* dag_elements_buf [[buffer(5)]],
    threadgroup uint* shared_mem [[threadgroup(0)]],
    uint lid [[thread_index_in_threadgroup]],
    uint gid [[thread_position_in_grid]]
) {
    ulong start_nonce = start_nonce_buf[0];
    ulong target = target_buf[0];
    // Each thread/lane gets its OWN nonce
    ulong nonce = start_nonce + gid;

    uint lane_id = lid & (PROGPOW_LANES - 1);
    uint group_id = lid / PROGPOW_LANES;

    threadgroup uint* c_dag = shared_mem;
    // Optimization #6: Coalesced DAG loading â€” threads load contiguous dag_t entries
    // so adjacent threads access adjacent memory addresses for better cache line utilization.
    // Thread 0 loads dag entry 0, thread 1 loads dag entry 1, etc.
    uint dag_elems = dag_elements_buf[0];
    for (uint entry = lid; entry < PROGPOW_CACHE_WORDS / PROGPOW_DAG_LOADS;
         entry += 256) {
        if (entry < dag_elems) {
            dag_t load = g_dag[entry];
            uint base = entry * PROGPOW_DAG_LOADS;
            for (int i = 0; i < PROGPOW_DAG_LOADS; i++)
                c_dag[base + i] = load.s[i];
        }
    }
    threadgroup_barrier(mem_flags::mem_threadgroup);

    // Share memory: 16 groups x 64 bytes each (matching OpenCL shuffle_t share[HASHES_PER_GROUP])
    // Each group occupies 8 ulongs = 16 uint32s = 64 bytes.
    // ulong indexing: share[group_id * 8]  (stride 64 bytes per group)
    // uint  indexing: share_u32[group_id * 16 + lane_id]  (stride 64 bytes per group)
    threadgroup uint* share_base = shared_mem + PROGPOW_CACHE_WORDS;
    threadgroup ulong* share = (threadgroup ulong*)(share_base);

    // Compute initial keccak and save state2 to device output buffer
    // Use a per-thread device buffer to avoid stack clobbering
    uint s2_0, s2_1, s2_2, s2_3, s2_4, s2_5, s2_6, s2_7;

    {
        uint state[25] = {0};
        for (int i = 0; i < 8; i++)
            state[i] = g_header->uint32s[i];
        state[8] = (uint)(nonce & 0xFFFFFFFF);
        state[9] = (uint)(nonce >> 32);
        for (int i = 10; i < 25; i++)
            state[i] = ravencoin_rndc[i - 10];
        keccak_f800(state);
        s2_0=state[0]; s2_1=state[1]; s2_2=state[2]; s2_3=state[3];
        s2_4=state[4]; s2_5=state[5]; s2_6=state[6]; s2_7=state[7];
    }
    // Force compiler to keep all s2 values by storing to threadgroup memory
    // (read back later for final keccak)
    threadgroup uint* tg_s2 = share_base + (PROGPOW_LANES * 16) + lid * 8;
    tg_s2[0]=s2_0; tg_s2[1]=s2_1; tg_s2[2]=s2_2; tg_s2[3]=s2_3;
    tg_s2[4]=s2_4; tg_s2[5]=s2_5; tg_s2[6]=s2_6; tg_s2[7]=s2_7;
    threadgroup_barrier(mem_flags::mem_threadgroup);

    hash32_t digest;
    // Optimization #5 & #7: Use simd_broadcast to eliminate threadgroup barriers
    // for lane communication within the PROGPOW_LANES loop.
    // Apple Silicon SIMD width is 32, PROGPOW_LANES is 16, so all lanes within
    // a SIMD group can communicate via simd_broadcast without barriers.
    // However, threads across SIMD groups (different groups within the threadgroup)
    // still need threadgroup memory for the progPowLoop share[] usage.
    for (uint h = 0; h < PROGPOW_LANES; h++) {
        uint mix[PROGPOW_REGS];

        // Optimization #7: Use simd_broadcast to get the elected lane's seed
        // instead of divergent if(lane_id == h) + barrier pattern.
        // Broadcast s2_0 and s2_1 from lane h to all lanes in the SIMD group.
        uint seed_s0 = simd_broadcast(s2_0, h);
        uint seed_s1 = simd_broadcast(s2_1, h);

        uint seed_share[2];
        seed_share[0] = seed_s0;
        seed_share[1] = seed_s1;
        fill_mix(seed_share, lane_id, mix);

        for (uint l = 0; l < PROGPOW_CNT_DAG; l++)
            progPowLoop(l, mix, g_dag, c_dag, share, lane_id, group_id);

        uint mix_hash = FNV_OFFSET_BASIS;
        for (int i = 0; i < PROGPOW_REGS; i++)
            mix_hash = fnv1a_func(mix_hash, mix[i]);

        hash32_t digest_temp;
        for (int i = 0; i < 8; i++)
            digest_temp.uint32s[i] = FNV_OFFSET_BASIS;

        // Optimization #5: Use simd_broadcast to gather mix_hash from all lanes
        // instead of writing to threadgroup memory + barrier + reading back.
        for (int i = 0; i < PROGPOW_LANES; i++) {
            uint lane_mix = simd_broadcast(mix_hash, i);
            digest_temp.uint32s[i % 8] = fnv1a_func(digest_temp.uint32s[i % 8], lane_mix);
        }

        if (h == lane_id)
            digest = digest_temp;
    }

    // Final keccak â€” read state2 from threadgroup memory
    ulong result;
    {
        uint state[25] = {0};
        for (int i = 0; i < 8; i++)
            state[i] = tg_s2[i];
        for (int i = 8; i < 16; i++)
            state[i] = digest.uint32s[i - 8];
        for (int i = 16; i < 25; i++)
            state[i] = ravencoin_rndc[i - 16];
        keccak_f800(state);
        // Byte-swap the result (match OpenCL as_ulong(as_uchar8(res).s76543210))
        ulong res = ((ulong)state[1] << 32) | state[0];
        result = ((res & 0xFF) << 56) | ((res & 0xFF00) << 40) | ((res & 0xFF0000) << 24) |
                 ((res & 0xFF000000) << 8) | ((res >> 8) & 0xFF000000) |
                 ((res >> 24) & 0xFF0000) | ((res >> 40) & 0xFF00) | ((res >> 56) & 0xFF);
    }

    if (result <= target) {
        uint slot = atomic_fetch_add_explicit(&g_output->count, 1u, memory_order_relaxed);
        if (slot < MAX_OUTPUTS) {
            g_output->gid[slot] = gid;
            g_output->nonce[slot] = nonce;
            for (int i = 0; i < 8; i++)
                g_output->mix[slot][i] = digest.uint32s[i];
        }
    }
}
