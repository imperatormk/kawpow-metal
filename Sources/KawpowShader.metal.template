#define PROGPOW_LANES 16
#define PROGPOW_REGS 32
#define PROGPOW_DAG_LOADS 4
#define PROGPOW_CACHE_WORDS 4096
#define PROGPOW_CNT_DAG 64
#define MAX_OUTPUTS 4

#define FNV_PRIME 0x01000193u
#define FNV_OFFSET_BASIS 0x811c9dc5u

#define ROTL32(x, n) (((x) << ((n) % 32)) | ((x) >> (32 - ((n) % 32))))
#define ROTR32(x, n) (((x) >> ((n) % 32)) | ((x) << (32 - ((n) % 32))))

#define NODE_WORDS 16
#define ETHASH_DATASET_PARENTS 512

typedef struct { uint s[PROGPOW_DAG_LOADS]; } dag_t;
typedef struct { uint uint32s[8]; } hash32_t;
typedef struct { uint words[NODE_WORDS]; } hash512_t;

typedef struct {
    atomic_uint count;
    uint gid[MAX_OUTPUTS];
    uint mix[MAX_OUTPUTS][8];
    ulong nonce[MAX_OUTPUTS];
} SearchResults;

