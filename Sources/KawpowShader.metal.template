// Direct port of ethash_keccakf800 from keccakf800.c
void keccak_f800(thread uint state[25]) {
    uint Aba=state[0],  Abe=state[1],  Abi=state[2],  Abo=state[3],  Abu=state[4];
    uint Aga=state[5],  Age=state[6],  Agi=state[7],  Ago=state[8],  Agu=state[9];
    uint Aka=state[10], Ake=state[11], Aki=state[12], Ako=state[13], Aku=state[14];
    uint Ama=state[15], Ame=state[16], Ami=state[17], Amo=state[18], Amu=state[19];
    uint Asa=state[20], Ase=state[21], Asi=state[22], Aso=state[23], Asu=state[24];
    uint Ba, Be, Bi, Bo, Bu, Da, De, Di, Do, Du;
    uint Eba,Ebe,Ebi,Ebo,Ebu,Ega,Ege,Egi,Ego,Egu;
    uint Eka,Eke,Eki,Eko,Eku,Ema,Eme,Emi,Emo,Emu;
    uint Esa,Ese,Esi,Eso,Esu;

    for (int round = 0; round < 22; round += 2) {
        // Round 0: Axx -> Exx
        Ba=Aba^Aga^Aka^Ama^Asa; Be=Abe^Age^Ake^Ame^Ase;
        Bi=Abi^Agi^Aki^Ami^Asi; Bo=Abo^Ago^Ako^Amo^Aso;
        Bu=Abu^Agu^Aku^Amu^Asu;
        Da=Bu^ROTL32(Be,1); De=Ba^ROTL32(Bi,1); Di=Be^ROTL32(Bo,1);
        Do=Bi^ROTL32(Bu,1); Du=Bo^ROTL32(Ba,1);

        Ba=Aba^Da; Be=ROTL32(Age^De,12); Bi=ROTL32(Aki^Di,11);
        Bo=ROTL32(Amo^Do,21); Bu=ROTL32(Asu^Du,14);
        Eba=Ba^(~Be&Bi)^keccakf_rndc[round]; Ebe=Be^(~Bi&Bo);
        Ebi=Bi^(~Bo&Bu); Ebo=Bo^(~Bu&Ba); Ebu=Bu^(~Ba&Be);

        Ba=ROTL32(Abo^Do,28); Be=ROTL32(Agu^Du,20); Bi=ROTL32(Aka^Da,3);
        Bo=ROTL32(Ame^De,13); Bu=ROTL32(Asi^Di,29);
        Ega=Ba^(~Be&Bi); Ege=Be^(~Bi&Bo); Egi=Bi^(~Bo&Bu);
        Ego=Bo^(~Bu&Ba); Egu=Bu^(~Ba&Be);

        Ba=ROTL32(Abe^De,1); Be=ROTL32(Agi^Di,6); Bi=ROTL32(Ako^Do,25);
        Bo=ROTL32(Amu^Du,8); Bu=ROTL32(Asa^Da,18);
        Eka=Ba^(~Be&Bi); Eke=Be^(~Bi&Bo); Eki=Bi^(~Bo&Bu);
        Eko=Bo^(~Bu&Ba); Eku=Bu^(~Ba&Be);

        Ba=ROTL32(Abu^Du,27); Be=ROTL32(Aga^Da,4); Bi=ROTL32(Ake^De,10);
        Bo=ROTL32(Ami^Di,15); Bu=ROTL32(Aso^Do,24);
        Ema=Ba^(~Be&Bi); Eme=Be^(~Bi&Bo); Emi=Bi^(~Bo&Bu);
        Emo=Bo^(~Bu&Ba); Emu=Bu^(~Ba&Be);

        Ba=ROTL32(Abi^Di,30); Be=ROTL32(Ago^Do,23); Bi=ROTL32(Aku^Du,7);
        Bo=ROTL32(Ama^Da,9); Bu=ROTL32(Ase^De,2);
        Esa=Ba^(~Be&Bi); Ese=Be^(~Bi&Bo); Esi=Bi^(~Bo&Bu);
        Eso=Bo^(~Bu&Ba); Esu=Bu^(~Ba&Be);

        // Round 1: Exx -> Axx
        Ba=Eba^Ega^Eka^Ema^Esa; Be=Ebe^Ege^Eke^Eme^Ese;
        Bi=Ebi^Egi^Eki^Emi^Esi; Bo=Ebo^Ego^Eko^Emo^Eso;
        Bu=Ebu^Egu^Eku^Emu^Esu;
        Da=Bu^ROTL32(Be,1); De=Ba^ROTL32(Bi,1); Di=Be^ROTL32(Bo,1);
        Do=Bi^ROTL32(Bu,1); Du=Bo^ROTL32(Ba,1);

        Ba=Eba^Da; Be=ROTL32(Ege^De,12); Bi=ROTL32(Eki^Di,11);
        Bo=ROTL32(Emo^Do,21); Bu=ROTL32(Esu^Du,14);
        Aba=Ba^(~Be&Bi)^keccakf_rndc[round+1]; Abe=Be^(~Bi&Bo);
        Abi=Bi^(~Bo&Bu); Abo=Bo^(~Bu&Ba); Abu=Bu^(~Ba&Be);

        Ba=ROTL32(Ebo^Do,28); Be=ROTL32(Egu^Du,20); Bi=ROTL32(Eka^Da,3);
        Bo=ROTL32(Eme^De,13); Bu=ROTL32(Esi^Di,29);
        Aga=Ba^(~Be&Bi); Age=Be^(~Bi&Bo); Agi=Bi^(~Bo&Bu);
        Ago=Bo^(~Bu&Ba); Agu=Bu^(~Ba&Be);

        Ba=ROTL32(Ebe^De,1); Be=ROTL32(Egi^Di,6); Bi=ROTL32(Eko^Do,25);
        Bo=ROTL32(Emu^Du,8); Bu=ROTL32(Esa^Da,18);
        Aka=Ba^(~Be&Bi); Ake=Be^(~Bi&Bo); Aki=Bi^(~Bo&Bu);
        Ako=Bo^(~Bu&Ba); Aku=Bu^(~Ba&Be);

        Ba=ROTL32(Ebu^Du,27); Be=ROTL32(Ega^Da,4); Bi=ROTL32(Eke^De,10);
        Bo=ROTL32(Emi^Di,15); Bu=ROTL32(Eso^Do,24);
        Ama=Ba^(~Be&Bi); Ame=Be^(~Bi&Bo); Ami=Bi^(~Bo&Bu);
        Amo=Bo^(~Bu&Ba); Amu=Bu^(~Ba&Be);

        Ba=ROTL32(Ebi^Di,30); Be=ROTL32(Ego^Do,23); Bi=ROTL32(Eku^Du,7);
        Bo=ROTL32(Ema^Da,9); Bu=ROTL32(Ese^De,2);
        Asa=Ba^(~Be&Bi); Ase=Be^(~Bi&Bo); Asi=Bi^(~Bo&Bu);
        Aso=Bo^(~Bu&Ba); Asu=Bu^(~Ba&Be);
    }
    state[0]=Aba; state[1]=Abe; state[2]=Abi; state[3]=Abo; state[4]=Abu;
    state[5]=Aga; state[6]=Age; state[7]=Agi; state[8]=Ago; state[9]=Agu;
    state[10]=Aka; state[11]=Ake; state[12]=Aki; state[13]=Ako; state[14]=Aku;
    state[15]=Ama; state[16]=Ame; state[17]=Ami; state[18]=Amo; state[19]=Amu;
    state[20]=Asa; state[21]=Ase; state[22]=Asi; state[23]=Aso; state[24]=Asu;
}

// ============================================================
// Keccak-f[1600] for DAG generation (Keccak-512)
// ============================================================

void keccak_f1600(thread ulong st[25]) {
    // Canonical Keccak-f[1600] with lookup tables for Rho Pi
    for (int round = 0; round < 24; round++) {
        ulong bc[5], t;
        // Theta
        for (int i = 0; i < 5; i++)
            bc[i] = st[i] ^ st[i + 5] ^ st[i + 10] ^ st[i + 15] ^ st[i + 20];
        for (int i = 0; i < 5; i++) {
            t = bc[(i + 4) % 5] ^ ((bc[(i + 1) % 5] << 1) | (bc[(i + 1) % 5] >> 63));
            for (int j = 0; j < 25; j += 5)
                st[j + i] ^= t;
        }

        // Rho Pi â€” using the standard permutation
        t = st[1];
        st[ 1] = (st[ 6] << 44) | (st[ 6] >> 20);
        st[ 6] = (st[ 9] << 20) | (st[ 9] >> 44);
        st[ 9] = (st[22] << 61) | (st[22] >>  3);
        st[22] = (st[14] << 39) | (st[14] >> 25);
        st[14] = (st[20] << 18) | (st[20] >> 46);
        st[20] = (st[ 2] << 62) | (st[ 2] >>  2);
        st[ 2] = (st[12] << 43) | (st[12] >> 21);
        st[12] = (st[13] << 25) | (st[13] >> 39);
        st[13] = (st[19] <<  8) | (st[19] >> 56);
        st[19] = (st[23] << 56) | (st[23] >>  8);
        st[23] = (st[15] << 41) | (st[15] >> 23);
        st[15] = (st[ 4] << 27) | (st[ 4] >> 37);
        st[ 4] = (st[24] << 14) | (st[24] >> 50);
        st[24] = (st[21] <<  2) | (st[21] >> 62);
        st[21] = (st[ 8] << 55) | (st[ 8] >>  9);
        st[ 8] = (st[16] << 45) | (st[16] >> 19);
        st[16] = (st[ 5] << 36) | (st[ 5] >> 28);
        st[ 5] = (st[ 3] << 28) | (st[ 3] >> 36);
        st[ 3] = (st[18] << 21) | (st[18] >> 43);
        st[18] = (st[17] << 15) | (st[17] >> 49);
        st[17] = (st[11] << 10) | (st[11] >> 54);
        st[11] = (st[ 7] <<  6) | (st[ 7] >> 58);
        st[ 7] = (st[10] <<  3) | (st[10] >> 61);
        st[10] = (t      <<  1) | (t      >> 63);

        // Chi
        for (int j = 0; j < 25; j += 5) {
            ulong tmp[5];
            for (int i = 0; i < 5; i++) tmp[i] = st[j + i];
            for (int i = 0; i < 5; i++)
                st[j + i] = tmp[i] ^ ((~tmp[(i + 1) % 5]) & tmp[(i + 2) % 5]);
        }

        st[0] ^= keccakf_1600_rndc[round];
    }
}

void keccak_512(thread uint data[16]) {
    ulong st[25] = {0};
    // Absorb 64 bytes (8 x uint64) into state
    for (int i = 0; i < 8; i++)
        st[i] = ((ulong)data[i * 2 + 1] << 32) | data[i * 2];
    // Keccak-512: rate = 72 bytes = 9 words, capacity = 128 bytes
    // Padding: 0x01 at byte 64 (word 8, byte 0) + 0x80 at byte 71 (word 8, byte 7)
    st[8] ^= 0x8000000000000001UL;
    keccak_f1600(st);
    // Extract 64 bytes (8 x uint64)
    for (int i = 0; i < 8; i++) {
        data[i * 2] = (uint)(st[i] & 0xFFFFFFFF);
        data[i * 2 + 1] = (uint)(st[i] >> 32);
    }
}

// ============================================================
// FNV helpers
// ============================================================

uint fnv1a_func(uint h, uint d) {
    return (h ^ d) * FNV_PRIME;
}

uint fnv_func(uint a, uint b) {
    return a * FNV_PRIME ^ b;
}

// ============================================================
// DAG Generation Kernel
// ============================================================

kernel void generate_dag(
    device hash512_t* g_dag [[buffer(0)]],
    device const hash512_t* g_light [[buffer(1)]],
    constant uint* params [[buffer(2)]],  // [0]=start, [1]=dag_total, [2]=light_items
    uint gid [[thread_position_in_grid]]
) {
    uint start = params[0];
    uint dag_total = params[1];
    uint light_items = params[2];
    uint node_index = start + gid;
    if (node_index >= dag_total) return;

    // Copy light cache item
    hash512_t node;
    uint src_idx = node_index % light_items;
    for (int i = 0; i < NODE_WORDS; i++)
        node.words[i] = g_light[src_idx].words[i];
    node.words[0] ^= node_index;

    // Keccak-512
    keccak_512(node.words);

    // Mix with parent nodes
    for (uint i = 0; i < ETHASH_DATASET_PARENTS; i++) {
        uint parent = fnv_func(node_index ^ i, node.words[i % NODE_WORDS]) % light_items;
        for (uint w = 0; w < NODE_WORDS; w++)
            node.words[w] = fnv_func(node.words[w], g_light[parent].words[w]);
    }

    // Final Keccak-512
    keccak_512(node.words);
    g_dag[node_index] = node;
}

// ============================================================
// Mix initialization
// ============================================================

void fill_mix(thread uint* seed, uint lane_id, thread uint mix[PROGPOW_REGS]) {
    uint fnv_hash = FNV_OFFSET_BASIS;
    uint z = fnv1a_func(fnv_hash, seed[0]);
    uint w = fnv1a_func(z, seed[1]);
    uint jsr = fnv1a_func(w, lane_id);
    uint jcong = fnv1a_func(jsr, lane_id);

    for (int i = 0; i < PROGPOW_REGS; i++) {
        z = 36969 * (z & 65535) + (z >> 16);
        w = 18000 * (w & 65535) + (w >> 16);
        uint mwc = (z << 16) + w;
        jcong = 69069 * jcong + 1234567;
        jsr ^= (jsr << 17); jsr ^= (jsr >> 13); jsr ^= (jsr << 5);
        mix[i] = (mwc ^ jcong) + jsr;
    }
}

